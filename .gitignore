# --- DEPENDENCIES ---
# Never commit this; it's huge and can be recreated with 'npm install'
node_modules/
jspm_packages/
web_modules/

# --- SECRETS & CONFIG ---
# Personal API keys and sensitive environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- BUILD & OUTPUT ---
# Folders where your compiled code (like from TypeScript) goes
dist/
build/
out/
.next/
.nuxt/

# --- LOGS ---
# Keeps your repo clean from error reports
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- TESTING ---
# Results from test runs (e.g., Jest or Mocha)
coverage/
*.lcov
.nyc_output/

# --- SYSTEM & IDE ---
# Editor settings that shouldn't be forced on other developers
.vscode/
.idea/
.DS_Store
Thumbs.db
